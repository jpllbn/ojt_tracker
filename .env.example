# Telegram bot token from @BotFather
BOT_TOKEN=your-bot-token-here

# Telegram user ID of the OJT coordinator (integer)
COORDINATOR_CHAT_ID=123456789

# Total OJT hours required per student (default: 486)
REQUIRED_HOURS=486

# Path to the SQLite database file (default: ojt_tracker.db)
DATABASE_PATH=ojt_tracker.db

# Daily time-in reminder (default: 08:00 PHT)
REMINDER_TIMEIN_HOUR=8
REMINDER_TIMEIN_MINUTE=0

# Daily time-out reminder (default: 17:30 PHT)
REMINDER_TIMEOUT_HOUR=17
REMINDER_TIMEOUT_MINUTE=30
